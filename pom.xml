												<prefix>/usr/local/SBB/usr/local/${project.artifactId}</prefix>
												<user>${project.artifactId}</user>
												<group>${project.artifactId}</group>
												<filemode>755</filemode>
											</mapper>
										</data>
										<data>
											<src>${project.build.directory}/classes/application.yml</src>
