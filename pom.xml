												<user>${project.artifactId}</user>
												<group>${project.artifactId}</group>
												<filemode>644</filemode>
											</mapper>
										</data>
										<data>
											<src>${basedir}/src/deb/files/${project.artifactId}.logrotate</src>
											<type>file</type>
											<conffile>true</conffile>
											<mapper>
												<type>perm</type>
