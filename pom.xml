								<configuration>
									<name>Staatsbibliothek zu Berlin - ${project.artifactId} - Filebeat
									</name>
									<classifier>filebeat</classifier>
									<controlDir>${project.basedir}/src/deb/${project.artifactId}-filebeat</controlDir>
									<deb>
										${project.build.directory}/${project.artifactId}-filebeat_${project.version}_all.deb
									</deb>
									<snapshotExpand>true</snapshotExpand>
									<signPackage>${sign.package}</signPackage>
									<signMethod>dpkg-sig</signMethod>
									<signRole>builder</signRole>
									<dataSet>
										<data>
											<type>template</type>
											<paths>
												<path>/var/run/${project.artifactId}-filebeat</path>
											</paths>
										</data>
										<data>
											<src>${basedir}/src/deb/files/filebeat-${project.artifactId}.yml</src>
											<type>file</type>
											<conffile>true</conffile>
